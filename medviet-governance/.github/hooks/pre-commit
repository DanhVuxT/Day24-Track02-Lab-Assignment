#!/bin/bash
set -e

echo "Running MedViet security checks..."

if command -v git-secrets >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
else
    echo "git-secrets not installed; skipping local secret pattern hook."
fi

echo "Running Bandit SAST..."
bandit -r src/ -ll -q

if command -v pip-audit >/dev/null 2>&1; then
    echo "Checking Python dependencies..."
    pip-audit --desc on
else
    echo "pip-audit not installed; skipping dependency CVE scan."
fi

echo "Security checks passed."
